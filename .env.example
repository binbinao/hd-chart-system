# Human Design Chart System - AI Configuration
# Copy this file to .env and fill in your values

# OpenAI or OpenAI-compatible API key (required for AI features)
AI_API_KEY=sk-your-api-key-here

# API base URL (default: OpenAI official)
# For other providers, change to their compatible endpoint:
#   DeepSeek:    https://api.deepseek.com/v1
#   Moonshot:    https://api.moonshot.cn/v1
#   Together:    https://api.together.xyz/v1
#   LocalAI:     http://localhost:8080/v1
AI_BASE_URL=https://api.openai.com/v1

# Model name (default: gpt-4o)
# Examples: gpt-4o, gpt-4o-mini, deepseek-chat, moonshot-v1-8k
AI_MODEL=gpt-4o

# Server port (default: 18090)
# PORT=18090

# Database path (default: hd_records.db in project root)
# HD_DB_PATH=/path/to/hd_records.db
